# ─────────────────────────────────────────────────────────────
# Morning Briefing Analyser — environment template
# Copy to packages/server/.env and fill in real values.
# ─────────────────────────────────────────────────────────────

# Server (4000 is often taken by other local apps — default 4400)
PORT=4400
NODE_ENV=development
LOG_LEVEL=info

# Scheduling (cron expression + timezone). Default: 10:15 AM daily.
BRIEF_CRON=15 10 * * *
BRIEF_TZ=Asia/Kolkata

# Database (Railway PostgreSQL or local)
DATABASE_URL=postgresql://user:password@localhost:5432/morning_briefing

# ── LLM provider (AI SDK) ──
# Default provider: openai | anthropic
LLM_PROVIDER=openai
LLM_MODEL_FAST=gpt-4o-mini
LLM_MODEL_SMART=gpt-4o
OPENAI_API_KEY=
# Optional — enables the Anthropic drop-in
ANTHROPIC_API_KEY=

# ── Slack (read-only + DM) ──
SLACK_USER_TOKEN=xoxp-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_DM_TARGET_USER_ID=U0000000000
# Comma-separated channel IDs to watch (provide later)
SLACK_PROJECT_CHANNELS=

# ── Jira Cloud ──
JIRA_BASE_URL=https://anatta-io.atlassian.net
JIRA_EMAIL=srittam@anattadesign.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEYS=EA
JIRA_BOARD_ID=1156

# ── Gmail (read-only) ──
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_MAX_UNREAD_PER_RUN=25

# ── Email delivery (Resend) ──
RESEND_API_KEY=
BRIEF_FROM_EMAIL=briefing@yourdomain.com
BRIEF_TO_EMAIL=srittam@anattadesign.com
